---
const { url } = Astro.props;

if (!url) {
  throw new Error('Google Fonts URL not found. Please set a URL.');
}

if (!url.startsWith('https://fonts.googleapis.com')) {
  throw new Error(
    'Google Fonts URL supplied does not start with https://fonts.googleapis.com',
  );
}
---

<link rel="preconnect" href="https://fonts.gstatic.com" />
<link rel="stylesheet" href={url} />
